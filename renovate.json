{
  "extends": [
    "config:recommended",
    "config:best-practices",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "packageRules": [
    {
      "groupSlug": "all",
      "allowedVersions": "!/^(?i).*[-_\\.](Alpha|Beta|RC|M|EA|Snap|snapshot|jboss|atlassian)[-_\\.]?[0-9]?.*$/",
      "groupName": "all dependencies",
      "matchPackageNames": [
        "*"
      ]
    }
  ]
}
